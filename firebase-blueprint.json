{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing roles and setup state.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["student", "employee"]
        },
        "updatedAt": {
          "type": "timestamp"
        }
      },
      "required": ["role", "updatedAt"]
    },
    "Decision": {
      "title": "Decision",
      "description": "Record of a decision made by an agent.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "agentId": {
          "type": "string"
        },
        "intuition": {
          "type": "number"
        },
        "result": {
          "type": "object"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["userId", "prompt", "agentId", "intuition", "result", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Feedback on a decision.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "decisionId": {
          "type": "string"
        },
        "accuracy": {
          "type": "number"
        },
        "usefulness": {
          "type": "number"
        },
        "comment": {
          "type": "string"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["userId", "decisionId", "accuracy", "usefulness", "comment", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles."
    },
    "decisions/{decisionId}": {
      "schema": {
        "$ref": "#/entities/Decision"
      },
      "description": "Decision records generated by swarm."
    },
    "feedback/{feedbackId}": {
      "schema": {
        "$ref": "#/entities/Feedback"
      },
      "description": "Feedback on decisions by users."
    }
  }
}
